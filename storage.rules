rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Room images — read public, write requires Firebase auth.
    // Admin-only and file-type enforcement happens server-side in /api/admin/upload.
    match /rooms/{imageId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    // User avatars
    match /avatars/{userId}/{imageId} {
      allow read:  if true;
      allow write: if request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
